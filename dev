#!/bin/sh
#
# StreamFlow Docker Compose Launcher
#
# Single-command local deployment with automatic secret generation.
# Secrets are generated on first run and stored in .env (gitignored).
#
# Usage:
#   ./dev up [--profile develop|deploy|profiling]
#   ./dev down
#   ./dev logs [-f]
#   ./dev ps
#   ./dev <any docker compose command>
#
# First run automatically:
#   1. Generates .env with secure random secrets
#   2. Generates RSA key pair for OAuth in dev-keys/

set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { printf "${GREEN}[dev]${NC} %s\n" "$1"; }
log_warn() { printf "${YELLOW}[dev]${NC} %s\n" "$1"; }

# Ensure environment is initialized
ensure_init() {
    if [ ! -f "$SCRIPT_DIR/.env" ] || [ ! -f "$SCRIPT_DIR/dev-keys/private.pem" ]; then
        log_info "First run detected - initializing environment..."
        "$SCRIPT_DIR/scripts/init.sh"
        echo
    fi
}

# Check if arguments contain a specific flag
has_flag() {
    flag="$1"
    shift
    for arg in "$@"; do
        if [ "$arg" = "$flag" ]; then
            return 0
        fi
    done
    return 1
}

# Show help
show_help() {
    cat << 'EOF'
StreamFlow Docker Compose Launcher

Usage: ./dev <command> [options]

Commands:
  up [--profile NAME]    Start StreamFlow (default profile: develop)
  down                   Stop all services
  logs [-f]              Show logs (use -f to follow)
  ps                     Show running containers
  build                  Build images
  pull                   Pull latest images
  restart                Restart services
  clean                  Stop and remove volumes (WARNING: deletes data)
  init                   Re-generate secrets and keys
  *                      Any other docker compose command

Profiles:
  develop    Development mode with hot reload (default)
  deploy     Production-like with prebuilt image
  profiling  Memory profiling with jemalloc

Examples:
  ./dev up                           # Start development environment
  ./dev up --profile deploy          # Start production-like environment
  ./dev up -d                        # Start detached
  ./dev logs -f                      # Follow logs
  ./dev down                         # Stop everything
  ./dev clean                        # Stop and delete all data

First run automatically generates:
  - .env with secure random secrets
  - dev-keys/ with RSA key pair for OAuth

EOF
}

# Main entrypoint
main() {
    cmd="${1:-}"

    case "$cmd" in
        -h|--help|help)
            show_help
            exit 0
            ;;
        "")
            show_help
            exit 0
            ;;
        up)
            ensure_init
            shift
            # Extract --profile flag (must come before 'up' in docker compose)
            profile=""
            other_args=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --profile)
                        profile="$2"
                        shift 2
                        ;;
                    *)
                        other_args="$other_args $1"
                        shift
                        ;;
                esac
            done
            if [ -n "$profile" ]; then
                log_info "Starting with profile: $profile"
                exec docker compose --profile "$profile" up $other_args
            else
                log_info "Starting with profile: develop"
                exec docker compose --profile develop up $other_args
            fi
            ;;
        down|stop)
            shift
            exec docker compose down "$@"
            ;;
        logs)
            shift
            exec docker compose logs "$@"
            ;;
        ps|status)
            shift
            exec docker compose ps "$@"
            ;;
        build)
            ensure_init
            shift
            exec docker compose build "$@"
            ;;
        clean)
            log_warn "This will delete all data volumes!"
            printf "Are you sure? [y/N] "
            read -r reply
            case "$reply" in
                [Yy]|[Yy][Ee][Ss])
                    docker compose down -v
                    log_info "Volumes removed"
                    ;;
                *)
                    log_info "Cancelled"
                    ;;
            esac
            ;;
        init)
            # Force re-initialization
            rm -f "$SCRIPT_DIR/.env"
            rm -rf "$SCRIPT_DIR/dev-keys"
            "$SCRIPT_DIR/scripts/init.sh"
            ;;
        *)
            ensure_init
            exec docker compose "$@"
            ;;
    esac
}

main "$@"
