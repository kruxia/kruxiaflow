{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                w.id,\n                w.status AS \"status: String\",\n                w.activities->>$2 AS activity_data,\n                COALESCE(\n                    (SELECT SUM(cost_usd)\n                     FROM activity_costs\n                     WHERE workflow_id = $1 AND activity_key = $2),\n                    0.0\n                ) AS \"cost_usd!\"\n            FROM workflows w\n            WHERE w.id = $1\n            ",
