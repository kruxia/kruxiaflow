{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                w.id,\n                w.status AS \"status: WorkflowStatus\",\n                w.activities,\n                w.updated_at,\n                COALESCE(\n                    (SELECT SUM(cost_usd)\n                     FROM activity_costs\n                     WHERE workflow_id = $1),\n                    0.0\n                ) AS \"total_cost_usd!\"\n            FROM workflows w\n            WHERE w.id = $1\n            ",
