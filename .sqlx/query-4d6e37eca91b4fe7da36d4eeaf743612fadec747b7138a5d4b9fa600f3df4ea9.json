{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, definition_name, status AS \"status: crate::WorkflowStatus\",\n                   created_at, updated_at\n            FROM workflows\n            WHERE ($1::TEXT IS NULL OR status::TEXT = $1)\n              AND ($2::TEXT IS NULL OR definition_name = $2)\n              AND ($3::TIMESTAMPTZ IS NULL OR created_at >= $3)\n              AND ($4::TIMESTAMPTZ IS NULL OR created_at < $4)\n            ORDER BY created_at DESC\n            LIMIT $5 OFFSET $6\n            ",
  "describe": {
    "columns": [
      {
        "ordinal": 0,
        "name": "id",
        "type_info": "Uuid"
      },
      {
        "ordinal": 1,
