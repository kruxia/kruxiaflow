  "query": "\n        SELECT\n            COUNT(DISTINCT workflow_id) as \"total_workflows!\",\n            COALESCE(SUM(cost_usd), 0.0) as \"total_cost!\",\n            COALESCE(AVG(cost_usd), 0.0) as \"avg_cost!\"\n        FROM activity_costs\n        WHERE created_at >= $1 AND created_at <= $2\n        ",
