#!/bin/bash
#
# Memory Profiling Script using jemalloc
#
# This script builds StreamFlow with jemalloc profiling enabled and runs
# the sustained throughput benchmark to capture heap allocation profiles.
#
# Usage:
#   ./scripts/profile_memory.sh [OPTIONS]
#
# Options:
#   --output-dir DIR    Directory for profiling output (default: var/memory-profile-TIMESTAMP)
#   --duration SECONDS  Test duration in seconds (default: 60)
#   --help, -h          Show this help message
#
# Requirements:
#   - jemalloc installed (brew install jemalloc on macOS)
#   - jeprof tool (comes with jemalloc)
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Default options
PROJECT_DIR=$(dirname "$(dirname "$0")")
OUTPUT_DIR="${PROJECT_DIR}/var/memory-profile-$(date +%Y%m%d-%H%M%S)"
DURATION=60

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --output-dir)
            OUTPUT_DIR="$2"
            shift 2
            ;;
        --duration)
            DURATION="$2"
            shift 2
            ;;
        --help|-h)
            grep '^#' "$0" | grep -v '#!/bin/bash' | sed 's/^# *//'
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Create output directory
mkdir -p "$OUTPUT_DIR"

echo -e "${YELLOW}StreamFlow Memory Profiling${NC}"
echo "======================================"
echo -e "${BLUE}Output directory: $OUTPUT_DIR${NC}"
echo -e "${BLUE}Test duration: ${DURATION}s${NC}"
echo ""

# Check for jemalloc
if ! command -v jeprof &> /dev/null; then
    echo -e "${RED}Error: jeprof not found${NC}"
    echo "Please install jemalloc:"
    echo "  macOS: brew install jemalloc"
    echo "  Linux: sudo apt-get install libjemalloc-dev"
    exit 1
fi

echo -e "${YELLOW}Building StreamFlow with jemalloc profiling...${NC}"
cargo build --profile profiling --features profiling

echo -e "${GREEN}Build complete${NC}"
echo ""

# Configure jemalloc profiling
export _RJEM_MALLOC_CONF="prof:true,prof_prefix:${OUTPUT_DIR}/jeprof.out,lg_prof_interval:30,lg_prof_sample:19"

echo -e "${YELLOW}Starting StreamFlow server with profiling enabled...${NC}"
echo "_RJEM_MALLOC_CONF=$_RJEM_MALLOC_CONF"
echo ""

# Run benchmark with monitoring
echo -e "${BLUE}Running sustained throughput benchmark for ${DURATION}s...${NC}"
${PROJECT_DIR}/scripts/profiling.sh --test test_sustained_throughput --trace-level debug --profile

echo ""
echo -e "${GREEN}Profiling complete!${NC}"
echo ""

# Find all heap dump files
HEAP_DUMPS=$(ls -t ${OUTPUT_DIR}/jeprof.out.*.heap 2>/dev/null || echo "")

if [ -z "$HEAP_DUMPS" ]; then
    echo -e "${YELLOW}Warning: No heap dump files found${NC}"
    echo "Profiling may not have been enabled correctly."
    exit 1
fi

echo -e "${BLUE}Heap dumps collected:${NC}"
echo "$HEAP_DUMPS" | while read dump; do
    echo "  - $dump"
done
echo ""

# Analyze the final heap dump
FINAL_DUMP=$(echo "$HEAP_DUMPS" | head -1)

echo -e "${YELLOW}Analyzing final heap dump...${NC}"
echo "File: $FINAL_DUMP"
echo ""

# Generate text report
echo -e "${BLUE}Generating allocation report...${NC}"
jeprof --show_bytes --text ${PROJECT_DIR}/target/profiling/streamflow "$FINAL_DUMP" > "${OUTPUT_DIR}/allocation_report.txt"

echo -e "${GREEN}Allocation report saved: ${OUTPUT_DIR}/allocation_report.txt${NC}"
echo ""

# Show top allocations
echo -e "${YELLOW}Top 20 Memory Allocations:${NC}"
echo "======================================"
head -30 "${OUTPUT_DIR}/allocation_report.txt"
echo ""

# Generate PDF if possible
if command -v dot &> /dev/null; then
    echo -e "${BLUE}Generating call graph PDF...${NC}"
    jeprof --show_bytes --pdf ${PROJECT_DIR}/target/profiling/streamflow "$FINAL_DUMP" > "${OUTPUT_DIR}/call_graph.pdf"
    echo -e "${GREEN}Call graph saved: ${OUTPUT_DIR}/call_graph.pdf${NC}"
else
    echo -e "${YELLOW}Skipping PDF generation (graphviz not installed)${NC}"
    echo "Install with: brew install graphviz"
fi

# Generate SVG flamegraph if possible
if command -v dot &> /dev/null; then
    echo -e "${BLUE}Generating flamegraph SVG...${NC}"
    jeprof --show_bytes --svg ${PROJECT_DIR}/target/profiling/streamflow "$FINAL_DUMP" > "${OUTPUT_DIR}/flamegraph.svg"
    echo -e "${GREEN}Flamegraph saved: ${OUTPUT_DIR}/flamegraph.svg${NC}"
    echo ""
    echo "Open with: open ${OUTPUT_DIR}/flamegraph.svg"
fi

echo ""
echo -e "${GREEN}Memory profiling complete!${NC}"
echo ""
echo "Results:"
echo "  - Allocation report: ${OUTPUT_DIR}/allocation_report.txt"
echo "  - Call graph PDF: ${OUTPUT_DIR}/call_graph.pdf (if graphviz installed)"
echo "  - Flamegraph SVG: ${OUTPUT_DIR}/flamegraph.svg (if graphviz installed)"
echo "  - Raw dumps: ${OUTPUT_DIR}/jeprof.out.*.heap"
echo ""
echo "Next steps:"
echo "  1. Review allocation_report.txt for top memory consumers"
echo "  2. Open flamegraph.svg to visualize allocation call paths"
echo "  3. Compare multiple dumps to track growth over time"
echo "  4. Look for unexpected large allocations or accumulations"
