# Kruxia Flow Docker Compose Configuration
# Copy to .env and customize for your environment
#
# SECURITY: Never commit .env files with real secrets to version control

# =============================================================================
# SECRETS - set these for any real deployment
# =============================================================================
# The compose file ships fixed local-development defaults so the quickstart
# runs standalone; they are safe only behind the default 127.0.0.1 binding.
# `./docker up` (via scripts/init.sh) generates secure random values here.

# PostgreSQL password (default: kruxiaflow-local — local development only)
POSTGRES_PASSWORD=your_secure_password_here

# OAuth client credentials for API authentication
# Generate a secure secret: openssl rand -base64 48
KRUXIAFLOW_CLIENT_ID=your-client-id
KRUXIAFLOW_CLIENT_SECRET=your_secure_client_secret_here

# Insecure dev mode - accepts unauthenticated requests, LOCAL EVALUATION ONLY
# KRUXIAFLOW_INSECURE_DEV=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL user (default: kruxiaflow)
# POSTGRES_USER=kruxiaflow

# PostgreSQL database name (default: kruxiaflow)
# POSTGRES_DB=kruxiaflow

# PostgreSQL host port (published on 127.0.0.1 by docker-compose.override.yml
# for local development; not published at all by the base file)
# POSTGRES_PORT=5432

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis is optional: enable the compose profile and the provider together
# COMPOSE_PROFILES=cache
# KRUXIAFLOW_CACHE_PROVIDER=redis

# Redis host port (published on 127.0.0.1 by docker-compose.override.yml)
# REDIS_PORT=6379

# =============================================================================
# KRUXIAFLOW API CONFIGURATION
# =============================================================================

# API server host port and bind address (default: 127.0.0.1:8080)
# Set KRUXIAFLOW_BIND=0.0.0.0 to expose to the network (secure it first!)
# KRUXIAFLOW_PORT=8080
# KRUXIAFLOW_BIND=127.0.0.1

# OAuth token issuer URL (default: http://localhost:8080)
# KRUXIAFLOW_OAUTH_TOKEN_ISSUER=http://localhost:8080

# OAuth token audience identifier (default: kruxiaflow-api)
# KRUXIAFLOW_OAUTH_TOKEN_AUDIENCE=kruxiaflow-api

# Number of worker threads for activity processing (default: 20)
# KRUXIAFLOW_WORKER_COUNT=20

# Maximum activities to poll per batch (default: 1)
# KRUXIAFLOW_WORKER_POLL_MAX_ACTIVITIES=1

# Worker poll interval in milliseconds (default: 100)
# KRUXIAFLOW_WORKER_POLL_INTERVAL_MS=100

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Cache provider: redis or noop (default: noop; requires the redis service —
# see COMPOSE_PROFILES under REDIS CONFIGURATION above)
# KRUXIAFLOW_CACHE_PROVIDER=redis

# =============================================================================
# LOGGING
# =============================================================================

# Log level: trace, debug, info, warn, error (default: info)
# KRUXIAFLOW_LOG_LEVEL=info

# =============================================================================
# QUEUE CONFIGURATION (for local development without Docker)
# =============================================================================

# Direct database connection for local development (without Docker)
# DATABASE_URL=postgres://kruxiaflow:${POSTGRES_PASSWORD}@127.0.0.1:5432/kruxiaflow

# Queue polling interval (default: 100ms)
# KRUXIAFLOW_QUEUE_POLL_INTERVAL=100ms

# Queue batch size for polling (default: 100)
# KRUXIAFLOW_QUEUE_BATCH_SIZE=100

# Default activity timeout (default: 60s)
# KRUXIAFLOW_QUEUE_DEFAULT_TIMEOUT=60s

# Default max retries for failed activities (default: 3)
# KRUXIAFLOW_QUEUE_DEFAULT_MAX_RETRIES=3

# Cleanup interval for completed activities (default: 60s)
# KRUXIAFLOW_QUEUE_CLEANUP_INTERVAL=60s

# Vacuum interval for PostgreSQL maintenance (default: 5m)
# KRUXIAFLOW_QUEUE_VACUUM_INTERVAL=5m

# Maximum database connections in pool (default: 20)
# KRUXIAFLOW_QUEUE_MAX_CONNECTIONS=20
