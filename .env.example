# StreamFlow Docker Compose Configuration
# Copy to .env and customize for your environment
#
# SECURITY: Never commit .env files with real secrets to version control

# =============================================================================
# REQUIRED - These must be set for any profile
# =============================================================================

# PostgreSQL password (no default - must be explicitly set)
POSTGRES_PASSWORD=your_secure_password_here

# OAuth client credentials for API authentication
# Generate a secure secret: openssl rand -base64 48
STREAMFLOW_CLIENT_ID=your-client-id
STREAMFLOW_CLIENT_SECRET=your_secure_client_secret_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL user (default: streamflow)
# POSTGRES_USER=streamflow

# PostgreSQL database name (default: streamflow)
# POSTGRES_DB=streamflow

# PostgreSQL port binding (default: 127.0.0.1:5432 - localhost only)
# Set to 0.0.0.0:5432 to expose to network (not recommended)
# POSTGRES_PORT=127.0.0.1:5432

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis port binding (default: 127.0.0.1:6379 - localhost only)
# REDIS_PORT=127.0.0.1:6379

# =============================================================================
# STREAMFLOW API CONFIGURATION
# =============================================================================

# API server port binding (default: 127.0.0.1:8080 for develop/profiling, 8080 for deploy)
# STREAMFLOW_PORT=127.0.0.1:8080

# OAuth token issuer URL (default: http://localhost:8080)
# STREAMFLOW_OAUTH_TOKEN_ISSUER=http://localhost:8080

# OAuth token audience identifier (default: streamflow-api)
# STREAMFLOW_OAUTH_TOKEN_AUDIENCE=streamflow-api

# Number of worker threads for activity processing (default: 20)
# STREAMFLOW_WORKER_COUNT=20

# Maximum activities to poll per batch (default: 1)
# STREAMFLOW_POLL_MAX_ACTIVITIES=1

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Cache provider: redis or memory (default: redis)
# STREAMFLOW_CACHE_PROVIDER=redis

# =============================================================================
# LOGGING
# =============================================================================

# Log level: trace, debug, info, warn, error (default: info)
# STREAMFLOW_LOG_LEVEL=info

# =============================================================================
# QUEUE CONFIGURATION (for local development without Docker)
# =============================================================================

# Direct database connection for local development (without Docker)
# DATABASE_URL=postgres://streamflow:${POSTGRES_PASSWORD}@127.0.0.1:5432/streamflow

# Queue polling interval (default: 100ms)
# STREAMFLOW_QUEUE_POLL_INTERVAL=100ms

# Queue batch size for polling (default: 100)
# STREAMFLOW_QUEUE_BATCH_SIZE=100

# Default activity timeout (default: 60s)
# STREAMFLOW_QUEUE_DEFAULT_TIMEOUT=60s

# Default max retries for failed activities (default: 3)
# STREAMFLOW_QUEUE_DEFAULT_MAX_RETRIES=3

# Cleanup interval for completed activities (default: 60s)
# STREAMFLOW_QUEUE_CLEANUP_INTERVAL=60s

# Vacuum interval for PostgreSQL maintenance (default: 5m)
# STREAMFLOW_QUEUE_VACUUM_INTERVAL=5m

# Maximum database connections in pool (default: 20)
# STREAMFLOW_QUEUE_MAX_CONNECTIONS=20
