# StreamFlow Configuration (for development)
# Copy this file to .env and adjust as needed

# Development database (used by API server and manual testing)
DATABASE_URL=postgres://streamflow:streamflow_dev@127.0.0.1:5433/streamflow

# Test database (automatically created/managed by scripts/test.sh)
# TEST_DATABASE_URL=postgres://streamflow:streamflow_dev@127.0.0.1:5433/streamflow_test

# Queue configuration
STREAMFLOW_QUEUE_POLL_INTERVAL=100ms
STREAMFLOW_QUEUE_BATCH_SIZE=100
STREAMFLOW_QUEUE_DEFAULT_TIMEOUT=60s
STREAMFLOW_QUEUE_DEFAULT_MAX_RETRIES=3
STREAMFLOW_QUEUE_CLEANUP_INTERVAL=60s
STREAMFLOW_QUEUE_VACUUM_INTERVAL=5m
STREAMFLOW_QUEUE_MAX_CONNECTIONS=20
